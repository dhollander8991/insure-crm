{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["cypress", "node", "testcafe"]
  },
  "include": ["cypress/**/*.ts", "cypress.config.ts"],
  "exclude": ["testcafe/**/*.ts"]
}
